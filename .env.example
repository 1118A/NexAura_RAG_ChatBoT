# =============================================================================
#  NexAura RAG Chat — Environment Variables Reference
#  Copy this file to .env and fill in your actual credentials.
#  NEVER commit .env with real keys to version control.
# =============================================================================

# ── LLM Provider API Keys ─────────────────────────────────────────────────────
# Get your Gemini key at: https://aistudio.google.com/apikey
Gemini_API=your_gemini_api_key_here

# Get your Groq key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Get your OpenAI key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ── ChromaDB Connection ───────────────────────────────────────────────────────
# CHROMA_MODE options: "local" (default) or "remote"
# Use "local" for development; "remote" for production with a hosted Chroma instance.
CHROMA_MODE=local

# Only required when CHROMA_MODE=remote:
CHROMA_HOST=api.trychroma.com
CHROMA_PORT=443
CHROMA_SSL=True
CHROMA_TENANT=your_chroma_tenant_id_here
CHROMA_DATABASE=your_chroma_database_name_here
CHROMA_API_KEY=your_chroma_api_key_here

# ── Application Settings ──────────────────────────────────────────────────────
# Name of the ChromaDB collection to store embeddings
COLLECTION_NAME=pdf_rag
